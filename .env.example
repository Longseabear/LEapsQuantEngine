KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_HTS_ID=your_hts_id

# Optional read-only account lookup.
KIS_CANO=12345678
KIS_ACNT_PRDT_CD=01

# Local legacy broker-engine bridge. The new engine uses this through an adapter,
# not as part of its deterministic core.
BROKER_ENGINE_BASE_URL=http://127.0.0.1:8755

# Optional defaults.
KIS_MOCK=false
KIS_API_RATE_LIMIT_PER_SECOND=15
DEFAULT_DOMESTIC_SYMBOL=005930
DEFAULT_OVERSEAS_SYMBOL=AAPL
DEFAULT_OVERSEAS_EXCHANGE=NAS
