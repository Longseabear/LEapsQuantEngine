{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leaps.local/schema/pipeline.schema.json",
  "title": "LEaps Quant Engine Pipeline",
  "type": "object",
  "required": ["engine", "sleeves"],
  "properties": {
    "engine": {
      "type": "object",
      "required": ["mode", "timezone"],
      "properties": {
        "mode": { "enum": ["backtest", "paper", "live"] },
        "timezone": { "type": "string" }
      },
      "additionalProperties": true
    },
    "data": {
      "type": "object",
      "properties": {
        "sample_prices": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      },
      "additionalProperties": true
    },
    "sleeves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
          "required": ["id", "cash", "algorithm"],
          "properties": {
            "id": { "type": "string" },
            "cash": { "type": "number", "minimum": 0 },
            "algorithm": { "type": "string" },
            "market": { "type": "string" },
            "max_position_pct": { "type": "number", "minimum": 0, "maximum": 1 },
            "symbols": {
              "type": "array",
              "items": { "type": "string" }
            },
            "universe": { "type": "string" },
            "parameters": {
              "type": "object",
              "additionalProperties": true
            }
          },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
