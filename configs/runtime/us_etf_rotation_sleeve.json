{
  "runtime_id": "us_etf_rotation",
  "mode": "live",
  "timezone": "Asia/Seoul",
  "market_data": {
    "provider": "market-data-engine",
    "history_provider": "kis-cache",
    "source": "market-data-engine",
    "history_source": "kis-cache",
    "rate_limit_per_second": 20
  },
  "broker_accounts": [
    {
      "account_id": "kis-overseas",
      "market_scope": "overseas",
      "currency": "USD",
      "account_store_path": "../../data/virtual-accounts/kis_overseas.json",
      "order_store_path": "../../data/order-runtime/kis_overseas.jsonl",
      "broker_gateway": "broker-engine",
      "metadata": {
        "kis_account_id": "us-growth",
        "note": "US ETF rotation account route. KIS credentials and account numbers are resolved from KIS_ACCOUNT_US_GROWTH_* env values."
      }
    }
  ],
  "journal_path": "../../data/cycle-journal/us_etf_rotation.jsonl",
  "sleeves": [
    {
      "sleeve_id": "us_etf_rotation",
      "workspace_path": "sleeves/us_etf_rotation",
      "broker_account_id": "kis-overseas",
      "broker_account_routes": {
        "overseas": "kis-overseas"
      },
      "cash": 0,
      "cash_by_currency": {
        "USD": 0
      },
      "universe": {
        "coarse_path": "configs/universes/us_etf_rotation_core.json",
        "fine": {
          "enabled": false,
          "refresh_seconds": 300,
          "max_age_seconds": 300
        },
        "active": {
          "max_symbols": 8,
          "selection_model": "leaps_quant_engine.universe.selection:StaticUniverseSelectionModel",
          "selection_models": [
            "selections/etf_rotation.py:EtfRotationSelectionModel",
            "selections/operational_symbols.py:OperationalSymbolsSelectionModel"
          ]
        }
      },
      "indicators": {
        "warmup_enabled": true,
        "extra_bars": 30,
        "min_ready_ratio": 1.0,
        "refresh_history": false
      },
      "alpha": {
        "modules": [
          {
            "ref": "alphas/etf_rotation.py",
            "enabled": true
          },
          {
            "ref": "alphas/volatility_trailing_stop.py",
            "enabled": true
          }
        ],
        "input_selections": {
          "us_etf_rotation": "us_etf_rotation",
          "us_etf_rotation-volatility-trailing-stop": "us_etf_rotation-operational-symbols"
        }
      },
        "portfolio": {
          "model": "portfolios/rl_ppo_constructor.py",
          "parameters": {
          "policy_path": null,
          "policy_paths": [
            "data/rl/us_etf_rotation/leaps_ppo_portfolio_allocator.zip"
          ],
          "metadata_path": "data/rl/us_etf_rotation/leaps_ppo_portfolio_allocator.json",
          "exposure_levels": [0.0, 0.25, 0.5, 0.75, 0.95],
          "fallback_action": 3,
          "top_k": 8,
          "model_name": "attention_ppo",
          "weight_temperature": 0.50,
          "min_position_pct": 0.0,
          "min_signal_action": 1,
          "allocation_mode": "rl_weights",
          "fallback_gross_exposure": 0.90,
          "max_portfolio_pct": 1.0,
          "max_position_pct": 0.35,
          "long_only": true
        },
        "rebalance": {
          "cash_reserve_pct": 0.02,
          "min_order_notional": 200.0,
          "min_quantity_delta": 2,
          "allow_exit_below_min_notional": true,
          "cadence": "every_5_minutes",
          "reused_target_churn_guard": true,
          "reused_target_churn_max_quantity_delta": 1,
          "reused_target_churn_lot_fraction": 0.5,
          "reused_target_churn_equity_bps": 10.0
        },
        "blend": {
          "enabled": true,
          "duration_minutes": 300,
          "target_drift_threshold_pct": 0.08,
          "clock": "orderable_session",
          "missing_target_behavior": "drop"
        }
      },
      "risk": {
        "model": "risks/basic.py",
        "parameters": {
          "long_only": true,
          "max_position_pct": 0.35,
          "max_total_exposure_pct": 0.98,
          "cash_buffer_pct": 0.02,
          "require_fresh_for_entries": true,
          "reject_invalid_snapshot": true
        }
      },
      "execution": {
        "model": "executions/immediate.py",
        "parameters": {
          "tag_prefix": "us_etf_rotation",
          "order_type": "limit",
          "time_in_force": "day",
          "limit_offset_bps": 0.0
        }
      },
      "worker": {
        "cycle_interval_seconds": 60,
        "min_success": 1
      }
    }
  ],
  "metadata": {
    "description": "USD-only ETF rotation sleeve. It selects US ETFs, emits ETF rotation insights, constructs equal-weight targets, and routes orders through the overseas broker account boundary."
  }
}
