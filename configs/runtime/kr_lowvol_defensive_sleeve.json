{
  "runtime_id": "kr-lowvol-defensive",
  "mode": "paper",
  "timezone": "Asia/Seoul",
  "market_data": {
    "provider": "market-data-engine",
    "history_provider": "kis-cache",
    "source": "market-data-engine",
    "history_source": "kis-cache",
    "rate_limit_per_second": 18
  },
  "broker_accounts": [
    {
      "account_id": "kr-lowvol-defensive-paper",
      "market_scope": "domestic",
      "currency": "KRW",
      "account_store_path": "../../data/virtual-accounts/kr_lowvol_defensive_paper.json",
      "order_store_path": "../../data/order-runtime/kr_lowvol_defensive_paper.jsonl",
      "broker_gateway": "paper",
      "metadata": {
        "note": "Paper route for the kr-lowvol-defensive sleeve. Live broker submission must be opted in separately."
      }
    }
  ],
  "journal_path": "../../data/cycle-journal/kr_lowvol_defensive.jsonl",
  "sleeves": [
    {
      "sleeve_id": "kr-lowvol-defensive",
      "workspace_path": "sleeves/kr-lowvol-defensive",
      "broker_account_id": "kr-lowvol-defensive-paper",
      "broker_account_routes": {
        "domestic": "kr-lowvol-defensive-paper"
      },
      "cash": 0,
      "cash_by_currency": {
        "KRW": 10000000
      },
      "universe": {
        "coarse_path": "configs/universes/kr_lowvol_defensive_core.json",
        "fine": {
          "enabled": false,
          "refresh_seconds": 300,
          "max_age_seconds": 300
        },
        "active": {
          "max_symbols": 40,
          "selection_model": "leaps_quant_engine.universe.selection:StaticUniverseSelectionModel",
          "selection_models": [
            "selections/lowvol_rank.py:LowVolDefensiveSelectionModel",
            "selections/operational_symbols.py:OperationalSymbolsSelectionModel"
          ]
        }
      },
      "indicators": {
        "warmup_enabled": true,
        "extra_bars": 160,
        "min_ready_ratio": 0.96,
        "refresh_history": false
      },
      "alpha": {
        "modules": [
          {
            "ref": "alphas/lowvol_defensive.py",
            "enabled": true
          }
        ],
        "input_selections": {
          "kr-lowvol-defensive-alpha": "kr-lowvol-defensive-core"
        }
      },
      "portfolio": {
        "model": "portfolios/inverse_vol.py",
        "parameters": {
          "top_k": 15,
          "core_gross_exposure": 1.0,
          "neutral_gross_exposure": 0.9,
          "defensive_gross_exposure": 0.75,
          "max_position_pct": 0.22,
          "min_position_pct": 0.015,
          "emit_zero_for_missing_held_targets": false,
          "stale_target_max_age_days": 28,
          "flat_stale_days": 14,
          "flat_return_band_pct": 0.015,
          "min_lot_value_multiple": 1.1
        },
        "rebalance": {
          "cash_reserve_pct": 0.02,
          "min_order_notional": 150000.0,
          "min_order_notional_equity_bps": 200.0,
          "min_quantity_delta": 1,
          "allow_exit_below_min_notional": true,
          "cadence": "week_start_at 08:55 Asia/Seoul",
          "reused_target_churn_guard": true,
          "reused_target_churn_max_quantity_delta": 2,
          "reused_target_churn_lot_fraction": 1.0,
          "reused_target_churn_equity_bps": 50.0
        },
        "target_resolution": {
          "mode": "patch"
        },
        "blend": {
          "enabled": true,
          "duration_minutes": 720,
          "target_drift_threshold_pct": 0.15,
          "clock": "orderable_session"
        }
      },
      "risk": {
        "model": "risks/basic.py",
        "parameters": {
          "long_only": true,
          "max_position_pct": 0.23,
          "max_total_exposure_pct": 0.98,
          "cash_buffer_pct": 0.02,
          "require_fresh_for_entries": true,
          "reject_invalid_snapshot": true
        }
      },
      "execution": {
        "model": "executions/immediate.py",
        "parameters": {
          "tag_prefix": "kr-lowvol-defensive",
          "order_type": "limit",
          "time_in_force": "day",
          "limit_offset_bps": 6.0,
          "max_slice_notional": 1000000,
          "max_slices": 4,
          "urgency": "patient",
          "max_order_age_seconds": 1200,
          "price_drift_bps": 70,
          "min_replace_interval_seconds": 240,
          "max_replacements": 2,
          "allow_sells": true,
          "buy_window": "09:05-14:50 Asia/Seoul",
          "window_timezone": "Asia/Seoul"
        }
      },
      "worker": {
        "cycle_interval_seconds": 300,
        "min_success": 1
      }
    }
  ],
  "metadata": {
    "description": "Paper runtime for a KRW-only defensive low-volatility Korean equity sleeve. V2 adds anti-lottery, anti-crowding, quality, value, and dividend factor metadata while staying separate from the LEaps growth/PPO sleeve."
  }
}
